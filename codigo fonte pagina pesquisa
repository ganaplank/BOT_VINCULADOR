    <script type="text/javascript" nonce="">

        //Inicio: SUS1657 | WS | 06/02/2020
        var isclosed = 0;
        function navtoggle() {
            if (isclosed === 1) {
                isclosed = 0;
                closeNav();
            }
            else {
                isclosed = 1;
                openNav();
            }
        }

        function closeNav() {
            document.getElementById("navlateral").style.width = "0";
        }

        function openNav() {
            document.getElementById("navlateral").style.width = "250px";
        }

        //Função chamada no inputchange do procura, validando se não é null ou espaços brancos
        function searchdiv() {
            input = document.getElementById("searchInput");
            filter = input.value.toUpperCase();

            if (filter === null || filter.match(/^ *$/) !== null)
                closeNav();
            else {
                openNav();
            }
            atualizarsearch();
        }

        function atualizarsearch() {
            var input, filter, ul, li, a, i, txtValue;

            input = document.getElementById("searchInput");
            filter = input.value.toUpperCase();
            divlateral = document.getElementById("navlateral");
            itensdiv = divlateral.getElementsByTagName("a");

            for (i = 0; i < itensdiv.length; i++) {
                itemdiv = itensdiv[i];
                txtValue = itemdiv.text;
                if (txtValue.toUpperCase().indexOf(filter) > -1) {
                    itensdiv[i].style.display = "";
                } else {
                    itensdiv[i].style.display = "none";
                }
            }
        }

        //Click fora do menu fecha o mesmo
        $(document).mouseup(function (e) {

            var container = $("#navlateral");

            if (!container.is(e.target) && container.has(e.target).length === 0) {
                closeNav();
                input = document.getElementById("searchInput");
                input.value = "";
                atualizarsearch();
            }
        });
        //Fim: SUS1657 | WS | 19/02/2020

        function reloadFrame() {
            document.getElementById('suporteIframe').src = '/bin/gerenciamento/suporte.asp';
            document.getElementById('suporteIframe').style.height = "300px";
        }

        function resizeIframe(obj) {
            obj.style.height = obj.contentWindow.document.body.scrollHeight + 'px';
        }

        document.addEventListener("DOMContentLoaded", function (e) {
            var menuButton = document.querySelector('.menuon');
            menuButton.onclick = function () {
                navtoggle();
            }

            var searchTxt = document.querySelector('#searchInput');
            searchTxt.oninput = function () {
                searchdiv();
            }

            var closebtnButton = document.querySelector('.closebtn');
            closebtnButton.onclick = function () {
                closeNav();
            }

            var editarPerfilButton = document.querySelector('.editarPerfil');
            editarPerfilButton.onclick = function () {
                TrocarConteudo('/bin/aplic/usuario.asp');
